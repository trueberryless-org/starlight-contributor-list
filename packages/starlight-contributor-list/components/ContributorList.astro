---
import { getAllContributors } from "../libs/getContributors";
import FacePile from "./FacePile.astro";

export interface Props {
  githubRepo?: `${string}/${string}`;
  ignore?: string[];
  focusColor?: string;
}

const {
  githubRepo = "withastro/docs",
  ignore,
  focusColor,
} = Astro.props as Props;

const contributors = await getAllContributors(githubRepo, ignore);
---

<FacePile {contributors} {focusColor} />
